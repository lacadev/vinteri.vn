{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "version": "1.0.0",
  "name": "lacadev/categories-gallery-block",
  "title": "Categories Gallery",
  "description": "Hiển thị danh mục dạng grid 6 cột với ảnh thumbnail",
  "category": "lacadev-blocks",
  "icon": "grid-view",
  "editorScript": "lacadev-block-categories-gallery-block-editor",
  "style": "lacadev-block-categories-gallery-block",
  "keywords": ["gallery", "categories", "taxonomy", "grid", "danh mục"],
  "textdomain": "laca",
  "attributes": {
    "subTitle": {
      "type": "string",
      "default": "Departments"
    },
    "title": {
      "type": "string",
      "default": "Featured Collections"
    },
    "browseAllText": {
      "type": "string",
      "default": "Browse All"
    },
    "browseAllUrl": {
      "type": "string",
      "default": ""
    },
    "postType": {
      "type": "string",
      "default": "post"
    },
    "taxonomy": {
      "type": "string",
      "default": "category"
    },
    "termIds": {
      "type": "array",
      "default": []
    },
    "backgroundColor": {
      "type": "string",
      "default": ""
    },
    "isFullWidth": {
      "type": "boolean",
      "default": false
    },
    "__isPreview": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "example": {
    "viewportWidth": 800,
    "attributes": {
      "subTitle": "Departments",
      "title": "Featured Collections",
      "browseAllText": "Browse All",
      "__isPreview": true
    }
  }
}
